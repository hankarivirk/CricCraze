# ══════════════════════════════════════════════
#   🏏  COSMIC CRICKET BOT — Environment Setup
# ══════════════════════════════════════════════
# Copy this file to .env and fill in your values

# ── Telegram API Credentials ──────────────────
# Get these from https://my.telegram.org
API_ID=your_api_id_here
API_HASH=your_api_hash_here

# ── Bot Token ─────────────────────────────────
# Get this from @BotFather on Telegram
BOT_TOKEN=your_bot_token_here

# ── Admin User ID ─────────────────────────────
# Your Telegram user ID (get from @userinfobot)
ADMIN_ID=your_user_id_here

# ── MongoDB URI ───────────────────────────────
# MongoDB Atlas: https://cloud.mongodb.com
# Format: mongodb+srv://user:pass@cluster.mongodb.net/
MONGO_URI=your_mongodb_uri_here

# ── Bot Links ─────────────────────────────────
# Your bot's play group link
PLAYZONE_LINK=https://t.me/your_group
# Your support group link
SUPPORT_LINK=https://t.me/your_support_group
